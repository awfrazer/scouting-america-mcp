# Required: scouting.org credentials (POSTed as JSON to auth.scouting.org to obtain a JWT).
# SCOUT_USERNAME is your my.scouting.org / Scoutbook Plus login name (NOT necessarily your email).
SCOUT_USERNAME=
SCOUT_PASSWORD=

# Optional: override the userId returned by login (defaults to the authenticated user)
# SCOUT_USER_ID=

# Optional: HTTP port (default 3032)
PORT=3032
